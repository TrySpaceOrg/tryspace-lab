# Jinja2 template for dynamic CLI Compose file
# Usage: Render with orchestrator using active CLI component
services:
  tryspace-sim:
    image: tryspace-server:latest
    container_name: tryspace-sim
    networks:
      - tryspace-net
    stdin_open: true
    tty: true
    environment:
      - NUM_CLIENTS=${NUM_CLIENTS:-1}
    command: ["/bin/sh", "-c", "/app/simulith_server_standalone $${NUM_CLIENTS}"]
    cpus: "4.0"
    mem_limit: 2g
    volumes:
      - simulith_ipc:/tmp
    tmpfs:
      - /dev/shm:noexec,nosuid,size=1g
    privileged: false

  tryspace-director:
    image: tryspace-director:latest
    container_name: tryspace-director
    networks:
      - tryspace-net
    stdin_open: true
    tty: true
    depends_on:
      - tryspace-sim
    command: ["/app/simulith_director_standalone"]
    cpus: "1.0"
    mem_limit: 512m
    volumes:
      - simulith_ipc:/tmp
    tmpfs:
      - /dev/shm:noexec,nosuid,size=100m

  tryspace-comp-{{ cli_component }}-cli:
    image: tryspace-comp-{{ cli_component }}-cli:latest
    container_name: tryspace-comp-{{ cli_component }}-cli
    networks:
      - tryspace-net
    stdin_open: true
    tty: true
    depends_on:
      - tryspace-sim
      - tryspace-director
    volumes:
      - simulith_ipc:/tmp
    tmpfs:
      - /dev/shm:noexec,nosuid,size=100m

networks:
  tryspace-net:
    driver: bridge

volumes:
  simulith_ipc:
    driver: local
